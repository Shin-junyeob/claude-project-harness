# 환경변수 예시 파일.
# 실제 값은 이 파일을 복사해 `.env` 로 만들어 채우세요:  cp .env.example .env
# `.env` 는 .gitignore 로 커밋 금지(비밀정보 차단 훅도 함께 막습니다).

# 예시 (필요한 것만 주석 해제해 사용)
# DATABASE_URL=
# API_KEY=
# SECRET_KEY=

# ── Claude Code 컨텍스트 관리 (선택, → rules/context_management.md) ──
# 기본값 권장(건드리지 않음). auto-compact 는 안전망이므로 끄지 말 것.
# 굳이 더 자주 compact 하려면 임계 %를 '낮춰서'만 조정(올리면 일관성 역효과):
# CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=70
# DISABLE_AUTO_COMPACT=1        # 비추천(하드리밋 충돌 위험)
